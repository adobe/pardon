{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "sourceMap": true,
    "incremental": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true
  },
  "exclude": ["./dist/**/*"]
}
